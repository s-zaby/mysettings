{
  "layer": "top",
  "position": "top",
  "height": 28,
  "spacing": 8,
  "modules-left": ["hyprland/workspaces", "hyprland/window"],
  "modules-center": ["clock"],
  "modules-right": ["cpu", "memory", "pulseaudio", "network", "tray", "battery"],

  "hyprland/workspaces": {
    "format": "{name}",
    "all-outputs": true,
    "on-click": "activate"
  },

  "hyprland/window": {
    "format": "{title}",
    "separate-outputs": true,
    "max-length": 50
  },

  "clock": {
    "format": "ΎΑΩ {:%a %b %d  %H:%M}",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
  },

  "cpu": {
    "format": "ΎΜδ {usage}%",
    "tooltip": true
  },

  "memory": {
    "format": "≤░Ξδ {percentage}%"
  },

  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "ΎΑο muted",
    "format-icons": {
      "default": ["ΎΑο", "ΎΑπ", "ΎΑρ"]
    }
  },

  "network": {
    "format-wifi": "ΎΘτ {essid} {signalStrength}%",
    "format-ethernet": "≤░ΙΑ connected",
    "format-disconnected": "≤░Ψς offline"
  },

  "tray": {
    "spacing": 10
  },

  "battery": {
    "format": "{icon} {capacity}%",
    "format-charging": "ΎΔπ {capacity}%",
    "format-plugged": "ΎΘο {capacity}%",
    "format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"]
  }
}
